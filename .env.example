# Pablo IDE — Environment Variables
# Copy this file to .env.local and fill in the values.

# ─── Authentication (GitHub OAuth) ─────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Auth secret — REQUIRED in production (SEC-06)
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ─── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000

# ─── Ollama Cloud LLM (CFG-01: correct endpoint) ──────────────────────────────
OLLAMA_URL=https://api.ollama.ai/v1
OLLAMA_API_KEY=

# ─── Cloudflare (deploy only) ─────────────────────────────────────────────────
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# ─── GitHub Webhook (optional — SEC-04: required for signature verification) ──
# GITHUB_WEBHOOK_SECRET=

# ─── Environment ───────────────────────────────────────────────────────────────
# Set to "production" on Cloudflare Workers
# ENVIRONMENT=production
